{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dygo.dev/schemas/schedule.schema.json",
  "title": "dygo Schedules",
  "description": "Schema for app-owned dygo _schedules.yml files. Runtime validation in Go remains authoritative.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schedules"],
  "properties": {
    "schedules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/schedule"
      },
      "default": []
    }
  },
  "$defs": {
    "kebabName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "jobRef": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*/[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "examples": ["sales/send-weekly-report"]
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "label", "cron", "timezone", "job"],
      "properties": {
        "name": {
          "$ref": "#/$defs/kebabName",
          "description": "App-local Schedule name."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-facing Schedule label."
        },
        "description": {
          "type": "string"
        },
        "cron": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "^(?:[Cc][Rr][Oo][Nn]_[Tt][Zz]|[Tt][Zz])="
          },
          "description": "Standard 5-field cron expression: minute hour day-of-month month day-of-week.",
          "examples": ["0 9 * * MON"]
        },
        "timezone": {
          "type": "string",
          "minLength": 1,
          "examples": ["Asia/Karachi", "UTC"]
        },
        "job": {
          "$ref": "#/$defs/jobRef",
          "description": "Target Job as <app>/<job>."
        },
        "enabled": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
