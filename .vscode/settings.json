{
  "yaml.schemas": {
    "./schemas/app.schema.json": [
      "apps/*/app.yml",
      ".dygo/apps/*/app.yml"
    ],
    "./schemas/entity.schema.json": [
      "apps/*/entities/*.yml",
      "apps/*/entities/*/*.yml",
      ".dygo/apps/*/entities/*.yml",
      ".dygo/apps/*/entities/*/*.yml"
    ],
    "./schemas/fixture.schema.json": [
      "apps/*/fixtures/*.yml",
      ".dygo/apps/*/fixtures/*.yml"
    ],
    "./schemas/patch.schema.json": [
      "apps/*/patches/*.yml",
      ".dygo/apps/*/patches/*.yml"
    ],
    "./schemas/config.schema.json": [
      "configs/dygo.yaml"
    ]
  },
  "yaml.validate": true
}
